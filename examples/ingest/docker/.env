KUDU_IMAGE=apache/kudu:1.18.1-ubuntu
PROMETHEUS_IMAGE=prom/prometheus:v2.52.0
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=12h
PUSHGATEWAY_IMAGE=prom/pushgateway:v1.8.0
PUSHGATEWAY_PORT=9091
GRAFANA_IMAGE=grafana/grafana:11.1.0
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
KUDU_MASTER=kudu-master:7051
INGEST_DATA_DIR=../data
INGEST_TSV_FILE=hits_100k.tsv
INGEST_METRICS_PORT=8080
INGEST_METRICS_PUSH_GATEWAY=pushgateway:9091
INGEST_METRICS_PUSH_JOB=kudu_ingest
INGEST_METRICS_OUTPUT=/data/ingest_metrics.json
INGEST_METRICS_KEEPALIVE_SECONDS=120
